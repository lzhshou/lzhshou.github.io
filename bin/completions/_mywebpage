#compdef mywebpage

_mywebpage() {
  local context state line
  typeset -A opt_args

  _arguments -C \
    '1: :->cmds' \
    '2: :->subcmds' \
    '*:: :->args' && return 0

  case "$state" in
    cmds)
      local -a cmds
      cmds=(
        'build:Build static site (opts: -c --clean -s --serve)'
        'deploy:Publish via docusaurus deploy (extra args after --)'
        'pdf:Export docs to PDF (build or open)'
        'server:Manage background dev server'
        'update:Reinstall mywebpage from repository'
        'uninstall:Remove mywebpage from system'
      )
      _describe -t commands 'mywebpage command' cmds
      ;;
    subcmds)
      case "$line[1]" in
        build)
          local -a bopts
          bopts=(
            '-c:Clear Docusaurus cache before build'
            '--clean:Clear Docusaurus cache before build'
            '-s:Serve the built site after successful build'
            '--serve:Serve the built site after successful build'
            '--help:Show build command help'
          )
          _describe -t options 'build option' bopts
          ;;
        server)
          local -a subcmds
          subcmds=(
            'start:Background serve with fixed port (optional port arg)'
            'stop:Stop background server'
            'status:Show port and health state'
            'restart:Stop then start server (optional port arg)'
          )
          _describe -t commands 'mywebpage server subcommand' subcmds
          ;;
        pdf)
          local -a subcmds
          subcmds=(
            'build:Export docs to PDF'
            'open:Export docs to PDF and open'
          )
          _describe -t commands 'mywebpage pdf subcommand' subcmds
          ;;
      esac
      ;;
    args)
      case "$line[1]" in
        build)
          case "$line[2]" in
            -s|--serve) _message -e 'port' 'optional TCP port (default 3000)' ;;
          esac
          ;;
        server)
          case "$line[2]" in
            start|restart) _message -e 'port' 'optional TCP port (default 3000)' ;;
          esac
          ;;
        pdf)
          local -a popts
          popts=(
            '-o:Output PDF path (default: static/pdf/apaam-lab-docs.pdf)'
            '--output:Output PDF path (default: static/pdf/apaam-lab-docs.pdf)'
            '-t:Cover page title'
            '--title:Cover page title'
            '-s:Cover page subtitle'
            '--subtitle:Cover page subtitle'
            '-d:Cover page date'
            '--date:Cover page date'
            '--help:Show pdf command help'
          )
          _describe -t options 'pdf option' popts
          ;;
      esac
      ;;
  esac
}

_mywebpage "$@"
