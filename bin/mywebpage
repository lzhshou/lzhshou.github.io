#!/usr/bin/env bash
# CLI for this Docusaurus site: build, deploy, server (start/stop/status/restart), update, uninstall.
# Stop uses listen port to find and clear the process.
# zsh (~/.zshrc): set once, use for PATH and fpath (must be before compinit):
#   MYWEBPAGE_BIN="/Users/.../myWebpage/bin"
#   export PATH="$MYWEBPAGE_BIN:$PATH"
#   fpath=("$MYWEBPAGE_BIN/completions" $fpath)
#   autoload -Uz compinit && compinit

set -euo pipefail

ROOT="${MYWEBPAGE_ROOT:-/Users/lzhshou/Documents/myWork/sysu/04-学术积累/mywebpage}"
STATE_DIR="${ROOT}/.mywebpage"
PORT_FILE="${STATE_DIR}/serve.port"
LOG_FILE="${STATE_DIR}/serve.log"
DEFAULT_PORT=3000

usage() {
  echo "Usage: mywebpage {build|deploy [args...]|server <subcmd>|update|uninstall}" >&2
  echo "  server start [port]   background serve (default port ${DEFAULT_PORT})" >&2
  echo "  server stop           stop background server" >&2
  echo "  server status         show port and state" >&2
  echo "  server restart [port] stop then start" >&2
  echo "  deploy                npm run deploy; sets GIT_USER via gh or git origin" >&2
  echo "  update                reinstall mywebpage from repository" >&2
  echo "  uninstall             remove mywebpage from system" >&2
  exit 1
}

server_usage() {
  echo "Usage: mywebpage server {start [port]|stop|status|restart [port]}" >&2
  exit 1
}

# PIDs with TCP listen on port (one per line).
pids_on_port() {
  local port="$1" out
  out="$(lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null || true)"
  if [[ -z "$out" ]]; then
    out="$(lsof -ti:"$port" -sTCP:LISTEN 2>/dev/null || true)"
  fi
  if [[ -z "$out" ]]; then
    out="$(lsof -ti:"$port" 2>/dev/null || true)"
  fi
  echo "$out" | tr ' ' '\n' | grep -E '^[0-9]+$' | sort -nu || true
}

cmd_build() {
  (cd "$ROOT" && npm run build)
}

cmd_deploy() {
  shift
  if [[ -z "${GIT_USER:-}" ]]; then
    local use_ssh_lc login origin
    use_ssh_lc="$(printf '%s' "${USE_SSH:-}" | tr '[:upper:]' '[:lower:]')"
    if [[ "$use_ssh_lc" != "true" ]]; then
      # gh is often missing from PATH when the script is not started from a login shell.
      PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
      if command -v gh >/dev/null 2>&1; then
        login="$(gh api user --jq .login 2>/dev/null)" || true
      fi
      if [[ -z "$login" ]]; then
        origin="$(git -C "$ROOT" remote get-url origin 2>/dev/null || true)"
        if [[ "$origin" =~ github\.com:([^/]+)/ ]]; then
          login="${BASH_REMATCH[1]}"
        elif [[ "$origin" =~ github\.com/([^/]+)/ ]]; then
          login="${BASH_REMATCH[1]}"
        fi
      fi
      [[ -n "$login" ]] && export GIT_USER="$login"
    fi
  fi
  (cd "$ROOT" && npm run deploy -- "$@")
}

cmd_server_start() {
  local port="${1:-}"
  [[ -z "$port" ]] && port="${MYWEBPAGE_PORT:-}"
  [[ -z "$port" ]] && port="$DEFAULT_PORT"

  if ! [[ "$port" =~ ^[0-9]+$ ]] || [[ "$port" -lt 1 ]] || [[ "$port" -gt 65535 ]]; then
    echo "mywebpage: invalid port: $port" >&2
    exit 1
  fi

  mkdir -p "$STATE_DIR"

  if [[ -n "$(pids_on_port "$port")" ]]; then
    echo "mywebpage: port $port is in use; run: mywebpage server stop" >&2
    exit 1
  fi

  echo "mywebpage: starting (build + serve on port $port), log: $LOG_FILE" >&2
  cd "$ROOT"
  nohup npx docusaurus serve --build --port "$port" --no-open >>"$LOG_FILE" 2>&1 &
  echo "$port" >"$PORT_FILE"
  echo "mywebpage: port $port" >&2
}

cmd_server_stop() {
  local port="$DEFAULT_PORT"
  [[ -f "$PORT_FILE" ]] && port="$(tr -d '[:space:]' <"$PORT_FILE")"

  if ! [[ "$port" =~ ^[0-9]+$ ]]; then
    port="$DEFAULT_PORT"
  fi

  local port_pids
  port_pids="$(pids_on_port "$port")"

  if [[ -z "$port_pids" ]]; then
    rm -f "$PORT_FILE"
    echo "mywebpage: nothing listening on port $port" >&2
    return 0
  fi

  local pid
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    kill -TERM "$pid" 2>/dev/null || true
  done < <(echo "$port_pids")

  local i
  for i in {1..40}; do
    [[ -z "$(pids_on_port "$port")" ]] && break
    sleep 0.2
  done

  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    kill -KILL "$pid" 2>/dev/null || true
  done < <(pids_on_port "$port")

  rm -f "$PORT_FILE"
  echo "mywebpage: stopped (port $port)" >&2
}

cmd_server_status() {
  local port="" port_busy=no has_state=no
  [[ -f "$PORT_FILE" ]] && has_state=yes

  [[ -f "$PORT_FILE" ]] && port="$(tr -d '[:space:]' <"$PORT_FILE")"

  if [[ "$has_state" == "no" ]]; then
    echo "log:     $LOG_FILE"
    echo "port:    —  (no mywebpage session; start uses port ${DEFAULT_PORT} by default)"
    echo "state:   stopped"
    return 0
  fi

  if ! [[ "$port" =~ ^[0-9]+$ ]]; then
    port="$DEFAULT_PORT"
  fi

  [[ -n "$(pids_on_port "$port")" ]] && port_busy=yes

  echo "log:     $LOG_FILE"
  echo "port:    $port  (listening: $port_busy)"

  if [[ "$port_busy" == "yes" ]]; then
    echo "state:   running"
  else
    echo "state:   stopped (stale state file — run: mywebpage server stop to clear)"
  fi
}

cmd_server_restart() {
  local port="${1:-}"
  cmd_server_stop
  sleep 0.5
  cmd_server_start "$port"
}

cmd_server() {
  local sub="${1:-}"
  case "$sub" in
    start) shift; cmd_server_start "$@" ;;
    stop) cmd_server_stop ;;
    status) cmd_server_status ;;
    restart) shift; cmd_server_restart "$@" ;;
    -h | --help | help) server_usage ;;
    *) server_usage ;;
  esac
}

cmd_update() {
  echo "mywebpage: updating..." >&2
  local repo_root
  repo_root="$ROOT"
  if [[ -f "${repo_root}/Makefile" ]]; then
    (cd "$repo_root" && make install)
  else
    echo "Error: Makefile not found at ${repo_root}" >&2
    exit 1
  fi
}

cmd_uninstall() {
  echo "mywebpage: uninstalling..." >&2
  local repo_root
  repo_root="$ROOT"
  if [[ -f "${repo_root}/Makefile" ]]; then
    (cd "$repo_root" && make uninstall)
  else
    echo "Error: Makefile not found at ${repo_root}" >&2
    exit 1
  fi
}

case "${1:-}" in
  build) cmd_build ;;
  deploy) cmd_deploy "$@" ;;
  server) shift; cmd_server "$@" ;;
  update) cmd_update ;;
  uninstall) cmd_uninstall ;;
  -h | --help | help) usage ;;
  *) usage ;;
esac
